#!/bin/bash

version="0.0.2"
reldate="2026/05/16"

# version management in /etc for more flexibility
if [ -f nanolx-orbit.conf ]; then
    source nanolx-orbit.conf
else
    source /usr/share/nanolx/nanolx-orbit.conf
fi

pkg_base="/var/cache/nanolx"
mkdir -p "${pkg_base}"

curl_opts="-L --progress-bar -C -"

downloader () {
    url="${1}"
    pkg="${2}"
    sha="${3}"
    out="${4}"

    if [ -f "${out}" ]; then
        echo -e "\nPackage ${pkg} (${out##*/}) already downloaded, verifying"
        if ! echo "${sha}" "${out}" | sha256sum -c &>/dev/null; then
            echo "SHA256 checksum for ${out} is wrong"
            noinst=true
        else
            echo "SHA256 checksum for ${out} is correct"
        fi
    else
        echo -e "\nDownloading ${pkg}: (${url##*/})"
        curl ${curl_opts} -o "${out}" "${url}"
        if ! echo "${sha}" "${out}" | sha256sum -c &>/dev/null; then
            echo "SHA256 checksum for ${out} is wrong"
            noinst=true
        else
            echo "SHA256 checksum for ${out} is correct"
        fi
    fi

}

installer () {
    pkg="${1}"

    if [[ "${mode}" = "in" ]]; then
        if [[ "${noinst}" = "false" ]]; then
            gdebi -n "${pkg}"
        else
            echo "not installing ${pkg} due to wrong SHA256 checksum"
        fi
    fi
}

download_packages () {
    mode="${1}"
    shift

    for pkg in "${@}"; do
        noinst=false
        case ${pkg} in
            discord )
                downloader "${discord_url}" discord "${discord_sha}" "${pkg_base}/${discord_url##*/}"
                installer "${pkg_base}/${discord_url##*/}"
            ;;
            zoom )
                downloader "${zoom_url}" zoom "${zoom_sha}" "${pkg_base}/${zoom_url##*/}"
                installer "${pkg_base}/${zoom_url##*/}"
            ;;
            zoom-vdi )
                downloader "${zoom_vdi_url}" zoom-vdi "${zoom_vdi_sha}" "${pkg_base}/${zoom_vdi_url##*/}"
                installer "${pkg_base}/${zoom_vdi_url##*/}"
            ;;
            jpeg8 )
                downloader "${jpeg8_url}" jpeg8 "${jpeg8_sha}" "${pkg_base}/${jpeg8_url##*/}"
                installer "${pkg_base}/${jpeg8_url##*/}"

                downloader "${jpeg_turbo8_url}" libjpeg-turbo8 "${libjpeg_turbo8_sha}" "${pkg_base}/${jpeg_turbo8_url##*/}"
                installer "${pkg_base}/${jpeg_turbo8_url##*/}"
            ;;
            citrix )
                downloader "${citrix_url}" citrix "${citrix_sha}" "${pkg_base}/${citrix_pkg}"
                installer "${pkg_base}/${citrix_pkg}"
            ;;
            citrix-usb )
                downloader "${citrix_usb_url}" citrix-usb "${citrix_usb_sha}" "${pkg_base}/${citrix_usb_pkg}"
                installer "${pkg_base}/${citrix_usb_pkg}"
            ;;
            * )
                echo "package ${pkg} unknown"
            ;;
        esac
    done
}

user_opt="${1}"
shift

case ${user_opt} in
    download )
        if [[ -z "${@}" ]]; then
            echo "no packages specified, exit."
            exit 0
        else
            download_packages dl "${@}"
        fi
    ;;

    install )
        if [[ -z "${@}" ]]; then
            echo "no packages specified, exit."
            exit 0
        else
            download_packages in "${@}"
        fi
    ;;

    list )
        echo "nanolx-orbit supports the following packages: ${package_list}"
    ;;

    clear )
        echo "removing downloaded packages from ${pkg_base}"
        rm -fv "${pkg_base}"/*
    ;;

    help | * )
        echo -e "nanolx-orbit v${version} (${reldate})
© 2026 Christopher Roy Bratusek <nano@jpberlin.de>

licensed under the GNU General Public License v3 (or newer)

usage:
    nanolx-orbit list
    nanolx-orbit download
    nanolx-orbit install
    nanolx-orbit clear
"
    ;;
esac
