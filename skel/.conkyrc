conky.config = {
    out_to_x = false,
    out_to_wayland = true,
    double_buffer = true,

    own_window = true,
    own_window_transparent = false,
    own_window_colour = '#000000',
    own_window_argb_visual = true,
    own_window_argb_value = 145,

    alignment = 'center',

    background = false,
    update_interval = 1,
    cpu_avg_samples = 2,
    net_avg_samples = 2,
    no_buffers = true,
    out_to_console = false,
    max_port_monitor_connections = 64,
    max_user_text = 16384,

    font = 'DejaVu Sans Mono:size=10',
    override_utf8_locale = true,
    uppercase = false,
    use_spacer = 'right',

    draw_borders = false,
    draw_graph_borders = true,
    draw_outline = false,
    draw_shades = false,
    border_width = 1,
    stippled_borders = 2,

    default_color = '#FFFFFF',
    default_outline_color = '#0077FF',
    default_shade_color = '#0077FF',
    color0 = '#0077FF',
    color1 = '#FCAF3E',
    color2 = '#55FC00',
    color3 = '#FF0019',
    color4 = '#EB00FF',
    color5 = '#FF9A00',
    color6 = '#FFEB00',
    color7 = '#00D0FF',
};

conky.text = [[
${color6}Debian GNU/Linux ${machine}${color0}${alignr}${kernel}

${color7}${time %d.%m.%Y}                        ${time %k:%M:%S}${alignr}${uptime}

${color6}AMD Ryzen 7 7800X3D
Speed: ${freq_g 0} GHz    Temp: ${hwmon k10temp temp 1}°C    ${cpubar 6,200}   Load: ${cpu cpu0} %

${color2}Fans
AIO:   ${hwmon nct6799 fan 2} RPM                    Chassis: ${hwmon nct6799 fan 7} RPM

${color4}Corsair Vengeance RGB
Usage:                            ${membar 6,200}   ${mem} / ${memmax}

${color5}AMD Radeon RX 9070
Temp:  ${hwmon amdgpu temp 1}°C       Load: ${execi 5 tr -d '\n' < /sys/class/drm/card0/device/gpu_busy_percent} %      VRAM: ${execi 30 awk '{printf "%.0f", $1/1024/1024}' /sys/class/drm/card0/device/mem_info_vram_used} / ${execi 30 awk '{printf "%.0f", $1/1024/1024}' /sys/class/drm/card0/device/mem_info_vram_total} MiB

${color7}Samsung 980                       /dev/nvme0                  Temp:       ${hwmon nvme temp 1}°C
Boot        ⇠ ${diskio_read /dev/nvme0n1p1} ⇢ ${diskio_write /dev/nvme0n1p1}   ${fs_bar 6,200 /boot}   ${fs_used /boot} / ${fs_size /boot}
Home        ⇠ ${diskio_read /dev/nvme0n1p2} ⇢ ${diskio_write /dev/nvme0n1p2}   ${fs_bar 6,200 /home}   ${fs_used /home} / ${fs_size /home}
Root        ⇠ ${diskio_read /dev/nvme0n1p4} ⇢ ${diskio_write /dev/nvme0n1p4}   ${fs_bar 6,200 /}   ${fs_used /} / ${fs_size /}

${color3}Samsung 980                       /dev/nvme1                  Temp:       ${hwmon nvme temp 2}°C
Win E       ⇠ ${diskio_read /dev/nvme1n1p2} ⇢ ${diskio_write /dev/nvme1n1p2}   ${fs_bar 6,200 /media/win_e}   ${fs_used /media/win_e} / ${fs_size /media/win_e}

${color0}Seagate Ironwolf Pro              /dev/sda                    Temp:       ${hwmon drivetemp temp 1}°C
Exchange    ⇠ ${diskio_read /dev/sda1} ⇢ ${diskio_write /dev/sda1}   ${fs_bar 6,200 /media/exchange}   ${fs_used /media/exchange} / ${fs_size /media/exchange}
Backup      ⇠ ${diskio_read /dev/sda2} ⇢ ${diskio_write /dev/sda2}   ${fs_bar 6,200 /media/backup}   ${fs_used /media/backup} / ${fs_size /media/backup}

${color2}Transcend TS64GSSD340             /dev/sdb                    Temp:       -- °C
EFI         ⇠ ${diskio_read /dev/sdb1} ⇢ ${diskio_write /dev/sdb1}   ${fs_bar 6,200 /boot/efi}   ${fs_used /boot/efi} / ${fs_size /boot/efi}
Playground  ⇠ ${diskio_read /dev/sdb2} ⇢ ${diskio_write /dev/sdb2}   ${fs_bar 6,200 /media/playground}   ${fs_used /media/playground} / ${fs_size /media/playground}

${color7}Mediatek MT7922                   Address:     ${addr wlp12s0}
Current: ⇣ ${downspeed wlp12s0}   ⇡ ${upspeed wlp12s0}    Total: ⇣ ${totaldown wlp12s0}   ⇡ ${totalup wlp12s0}
]];
